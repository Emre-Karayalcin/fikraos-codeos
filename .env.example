# Database Configuration
DATABASE_URL=postgresql://localhost/fikraos
# DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=your-secure-random-session-secret-here

# AI API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
PERPLEXITY_API_KEY=pplx-your-key-here

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT_DEV=https://your-azure-endpoint.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY_DEV=your-azure-openai-api-key-here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-fikra-dev

# Azure OpenAI Realtime API (for voice conversations)
AZURE_OPENAI_REALTIME_ENDPOINT=https://your-realtime-endpoint.cognitiveservices.azure.com
AZURE_OPENAI_REALTIME_API_KEY=your-realtime-api-key-here
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime
AZURE_OPENAI_REALTIME_API_VERSION=2024-10-01-preview

# News & Media APIs
NEWSDATA_API_KEY=pub_your-newsdata-key-here

# Deprecated (replaced by Azure OpenAI)
# OPENAI_API_KEY=sk-your-openai-key-here
# ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Presentation APIs
SLIDESPEAK_API_KEY=your-slidespeak-key-here

# Email Service (Optional)
RESEND_API_KEY=re_your-resend-key-here

# Calendly Integration (Optional, for generated one-time scheduling links)
CALENDLY_PAT_TOKEN=your-calendly-personal-access-token
CALENDLY_API_BASE=https://api.calendly.com

# Google Services (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ✅ SECURITY: Google Drive Service Account (for PPTX to PDF conversion)
# IMPORTANT: Never commit actual credentials to git. Use environment variables.
# Obtain these from Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-service-account-client-id

# Application URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5000
PRODUCTION_URL=https://your-domain.com

# Feature Flags (Optional)
ENABLE_AI_FEATURES=true
ENABLE_EMAIL_NOTIFICATIONS=false
